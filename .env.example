# Podcast Learning Companion Configuration

# Anthropic API Key (required for Phase 3: AI summaries, Q&A, quizzes)
ANTHROPIC_API_KEY=

# Database
DATABASE_PATH=data/podcast_learning.db

# Audio storage
AUDIO_DIR=data/audio

# Huey task queue
HUEY_DB_PATH=data/huey.db

# Whisper transcription settings
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# Auto-processing
AUTO_DOWNLOAD_RECENT=5
